{
  "name": "oewang",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "typecheck": "turbo run typecheck",
    "migrate": "turbo run migrate",
    "mcp": "bun run --cwd apps/api mcp.ts",
    "setup:stripe": "bun run --cwd packages/database setup:stripe"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "prettier": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.3",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "catalog": {
    "typescript": "5.9.2",
    "@biomejs/biome": "2.3.14",
    "prettier": "3.7.4",
    "turbo": "2.8.5",
    "zod": "3.25.76",
    "date-fns": "4.1.0",
    "next": "16.1.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "lucide-react": "0.575.0",
    "clsx": "2.1.1",
    "tailwind-merge": "3.4.0",
    "sonner": "2.0.7",
    "radix-ui": "1.4.3",
    "drizzle-orm": "0.45.1",
    "nuqs": "2.8.9"
  }
}
